Questão 29
Verifique se um número é primo.
int numero = int.Parse(Console.ReadLine());

int divisor = 2;
bool primo = true;

while (divisor < numero)
{
    if (numero % divisor == 0)
    {
        primo = false;
        break;
    }

    divisor++;
}

if (primo && numero > 1)
{
    Console.WriteLine("Primo");
}
else
{
    Console.WriteLine("Não primo");
}


